# Sovyx Dashboard — Environment Variables
#
# Copy to .env.local for local development.
# All variables are optional — defaults work for standard setup.

# API base URL (default: same origin as dashboard)
# Set this when running frontend dev server separately from backend.
# Example: VITE_API_URL=http://localhost:7777
VITE_API_URL=

# WebSocket base URL (default: ws://<current host>)
# Only set if WS runs on a different port/host than the page.
# Example: VITE_WS_URL=ws://localhost:7777
VITE_WS_URL=
