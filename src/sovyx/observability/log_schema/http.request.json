{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/http.request.json",
  "title": "http.request",
  "description": "Dashboard HTTP request \u2014 method, path, status, latency.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "net.method",
    "net.path",
    "net.client",
    "net.request_bytes"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "http.request"
    },
    "net.method": {
      "type": "string"
    },
    "net.path": {
      "type": "string"
    },
    "net.client": {
      "type": "string"
    },
    "net.request_bytes": {
      "type": "integer"
    },
    "net.status_code": {
      "type": "integer"
    },
    "net.response_bytes": {
      "type": "integer"
    },
    "net.latency_ms": {
      "type": "integer"
    },
    "net.failed": {
      "type": "boolean"
    },
    "net.error_type": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
