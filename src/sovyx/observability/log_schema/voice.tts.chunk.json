{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/voice.tts.chunk.json",
  "title": "voice.tts.chunk",
  "description": "Per-chunk TTS generation timing (audio_ms vs wall-clock ms).",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "voice.chunk_index",
    "voice.text_chars",
    "voice.audio_ms",
    "voice.generation_ms",
    "voice.model",
    "voice.voice",
    "voice.sample_rate"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "voice.tts.chunk"
    },
    "voice.chunk_index": {
      "type": "integer"
    },
    "voice.text_chars": {
      "type": "integer"
    },
    "voice.audio_ms": {
      "type": "number"
    },
    "voice.generation_ms": {
      "type": "number"
    },
    "voice.model": {
      "type": "string"
    },
    "voice.voice": {
      "type": "string"
    },
    "voice.sample_rate": {
      "type": "integer"
    },
    "voice.speaker_id": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
