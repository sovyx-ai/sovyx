{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/voice.wake.score.json",
  "title": "voice.wake.score",
  "description": "OpenWakeWord score per inference window.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "voice.score",
    "voice.threshold",
    "voice.stage2_threshold",
    "voice.cooldown_ms_remaining",
    "voice.state",
    "voice.model_name"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "voice.wake.score"
    },
    "voice.score": {
      "type": "number"
    },
    "voice.threshold": {
      "type": "number"
    },
    "voice.stage2_threshold": {
      "type": "number"
    },
    "voice.cooldown_ms_remaining": {
      "type": "integer"
    },
    "voice.state": {
      "type": "string"
    },
    "voice.model_name": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
