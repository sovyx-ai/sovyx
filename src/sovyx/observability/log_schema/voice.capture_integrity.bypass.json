{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/voice.capture_integrity.bypass.json",
  "title": "voice.capture_integrity.bypass",
  "description": "Mission H2 neutral platform-bypass cascade event; carries v2.0.0 metadata.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "voice.mind_id",
    "voice.platform",
    "voice.bypass_family",
    "voice.event_schema_version"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "voice.capture_integrity.bypass"
    },
    "voice.mind_id": {
      "type": "string"
    },
    "voice.platform": {
      "type": "string"
    },
    "voice.bypass_family": {
      "type": "string"
    },
    "voice.event_schema_version": {
      "type": "string"
    },
    "voice.consecutive_deaf_warnings": {
      "type": "integer"
    },
    "voice.threshold": {
      "type": "integer"
    },
    "voice.voice_clarity_active": {
      "type": "boolean"
    },
    "voice.auto_bypass_enabled": {
      "type": "boolean"
    },
    "voice.strategy_name": {
      "type": "string"
    },
    "voice.attempt_index": {
      "type": "integer"
    },
    "voice.verdict": {
      "type": "string"
    },
    "voice.attempts": {
      "type": "integer"
    },
    "voice.strategies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "voice.outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "voice.error": {
      "type": "string"
    },
    "voice.error_type": {
      "type": "string"
    },
    "voice.reason": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
