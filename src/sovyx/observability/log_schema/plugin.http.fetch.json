{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/plugin.http.fetch.json",
  "title": "plugin.http.fetch",
  "description": "SandboxedHttpClient.request() \u2014 request log + paired response log.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "plugin_id",
    "plugin.http.method",
    "plugin.http.url_host_only",
    "plugin.http.headers_redacted",
    "plugin.http.body_bytes",
    "plugin.http.allowed_domain",
    "plugin.http.rate_limited"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "plugin.http.fetch"
    },
    "plugin_id": {
      "type": "string"
    },
    "plugin.http.method": {
      "type": "string"
    },
    "plugin.http.url_host_only": {
      "type": "string"
    },
    "plugin.http.headers_redacted": {
      "type": "boolean"
    },
    "plugin.http.body_bytes": {
      "type": "integer"
    },
    "plugin.http.allowed_domain": {
      "type": "boolean"
    },
    "plugin.http.rate_limited": {
      "type": "boolean"
    },
    "plugin.http.status": {
      "type": "integer"
    },
    "plugin.http.response_bytes": {
      "type": "integer"
    },
    "plugin.http.latency_ms": {
      "type": "number"
    },
    "plugin.http.attempt": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
