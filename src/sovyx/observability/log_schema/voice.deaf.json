{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/voice.deaf.json",
  "title": "voice.deaf",
  "description": "Capture stream is wedged \u2014 VAD probability stayed below floor.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "voice.mind_id",
    "voice.state",
    "voice.consecutive_deaf_warnings",
    "voice.threshold",
    "voice.max_vad_probability",
    "voice.frames_processed",
    "voice.voice_clarity_active"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "voice.deaf"
    },
    "voice.mind_id": {
      "type": "string"
    },
    "voice.state": {
      "type": "string"
    },
    "voice.consecutive_deaf_warnings": {
      "type": "integer"
    },
    "voice.threshold": {
      "type": "integer"
    },
    "voice.max_vad_probability": {
      "type": "number"
    },
    "voice.frames_processed": {
      "type": "integer"
    },
    "voice.voice_clarity_active": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
