{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/voice.device.hotplug.json",
  "title": "voice.device.hotplug",
  "description": "OS audio endpoint changed (arrival / removal / default switch).",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "voice.device_id",
    "voice.device_name",
    "voice.event_type",
    "voice.endpoint_guid"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "voice.device.hotplug"
    },
    "voice.device_id": {
      "type": "string"
    },
    "voice.device_name": {
      "type": "string"
    },
    "voice.event_type": {
      "type": "string"
    },
    "voice.endpoint_guid": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
