{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovyx.dev/log_schema/config.value.resolved.json",
  "title": "config.value.resolved",
  "description": "Startup cascade emitted the resolved value for one EngineConfig field.",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "logger",
    "event",
    "schema_version",
    "process_id",
    "host",
    "sovyx_version",
    "sequence_no",
    "cfg.field",
    "cfg.source",
    "cfg.value"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "enum": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "logger": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "process_id": {
      "type": "integer",
      "minimum": 1
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "sovyx_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 0
    },
    "saga_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cause_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event": {
      "const": "config.value.resolved"
    },
    "cfg.field": {
      "type": "string"
    },
    "cfg.source": {
      "type": "string"
    },
    "cfg.value": {
      "type": "string"
    },
    "cfg.env_key": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
